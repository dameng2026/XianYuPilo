# Xianyu Assistant production environment template
#
# Copy this file to .env, fill every REQUIRED blank, then run start.sh or
# start.bat. Never commit .env. Generate a different random value for every
# secret; do not reuse database, Redis, JWT, cookie, or internal API secrets.
# Create ./secrets with mode 0700 and each referenced regular file with mode
# 0600. Each file contains one UTF-8 logical line (one trailing newline is OK).
# Disabled optional integrations still use an empty protected file.

# ===== Runtime =====
APP_ENV=production
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=8080
# Add the real public hostname before exposing the service, for example:
# TRUSTED_HOSTS=assistant.example.com,localhost,127.0.0.1,api
TRUSTED_HOSTS=localhost,127.0.0.1,api
TRUSTED_PROXY_IPS=172.30.240.20/32
# Same-origin browser traffic needs no CORS entry. If separate origins are
# required, use an explicit comma-separated HTTPS allowlist; never use *.
CORS_ALLOWED_ORIGINS=
PUBLIC_BASE_URL=

# ===== Administrator (REQUIRED) =====
ADMIN_USERNAME=admin
# REQUIRED: bcrypt hash with cost 12 or higher. Never put the plaintext password here.
ADMIN_PASSWORD_HASH_FILE=./secrets/admin-password-hash

# ===== MySQL (REQUIRED) =====
MYSQL_DATABASE=xianyu_opensource
# Runtime API/worker identity: DML only (SELECT/INSERT/UPDATE/DELETE).
MYSQL_APP_USER=xianyu_app
MYSQL_APP_PASSWORD_FILE=./secrets/mysql-app-password
# One-shot migration identity: schema DDL plus DML, never used by API/worker.
MYSQL_MIGRATION_USER=xianyu_migrate
MYSQL_MIGRATION_PASSWORD_FILE=./secrets/mysql-migration-password
# Used only by the MySQL container for administration and disaster recovery.
MYSQL_ROOT_PASSWORD_FILE=./secrets/mysql-root-password

# ===== Redis (REQUIRED) =====
REDIS_PASSWORD_FILE=./secrets/redis-password

# ===== Cryptographic boundaries (REQUIRED, unique, >= 32 characters each) =====
JWT_SECRET_FILE=./secrets/jwt-secret
COOKIE_CRYPTO_SECRET_FILE=./secrets/cookie-crypto-secret
INTERNAL_API_TOKEN_FILE=./secrets/internal-api-token
JWT_EXPIRATION_MS=43200000
JWT_ISSUER=xianyu-assistant-api
JWT_AUDIENCE=xianyu-assistant-web

# ===== API safety limits =====
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
API_RATE_LIMIT_PER_MINUTE=600
AUDIT_LOG_RETENTION_DAYS=90
# Keep the template fail-closed. Production/staging validation requires an
# operator to set this to true after the audit schema and retention worker are ready.
AUDIT_MUTATION_INTENT_REQUIRED=false
MAX_REQUEST_BODY_BYTES=12582912
MAX_UPLOAD_BYTES=10485760

# ===== Scheduled task worker =====
SCHEDULER_POLL_INTERVAL_SECONDS=15
SCHEDULER_TASK_TIMEOUT_SECONDS=300
# Must be at least 30 seconds longer than the task timeout.
SCHEDULER_LEASE_SECONDS=360
SCHEDULER_BATCH_SIZE=20
SCHEDULER_HEARTBEAT_MAX_AGE_SECONDS=60

# ===== Crawler service =====
# Crawler and API ports are intentionally not published by Compose.
CRAWLER_JSON_LIMIT=256kb
CRAWLER_RATE_LIMIT_WINDOW_MS=60000
CRAWLER_RATE_LIMIT_MAX=60
CRAWLER_MAX_CONCURRENCY=2
CRAWLER_MAX_SESSIONS=100
CRAWLER_SESSION_TTL_MS=1800000
CRAWLER_OPERATION_TIMEOUT_MS=180000
CRAWLER_MAX_COOKIE_BYTES=65536
CRAWLER_ALLOWED_TARGET_HOSTS=goofish.com,taobao.com
CRAWLER_ALLOWED_ORIGINS=
CRAWLER_FORCE_HEADLESS=true
# Hardened Compose isolation is enabled; disabling the Chromium process sandbox
# is the compatibility default inside that container boundary.
PLAYWRIGHT_DISABLE_SANDBOX=true

# ===== Optional commercial bridge (server-side only) =====
# Leave all values blank to disable the bridge. Use HTTPS URLs in production.
COMMERCIAL_FRONTEND_URL=
COMMERCIAL_ADMIN_URL=
COMMERCIAL_BACKEND_BASE_URL=
COMMERCIAL_BACKEND_HEALTH_PATH=/admin-api/health
COMMERCIAL_BACKEND_ADMIN_HEALTH_PATH=/admin-api/health
COMMERCIAL_BACKEND_USER_HEALTH_PATH=/api/health
COMMERCIAL_BACKEND_BRIDGE_PREFIX=/admin-api/open-source-bridge
COMMERCIAL_BACKEND_ACCESS_TOKEN_FILE=./secrets/commercial-backend-access-token
COMMERCIAL_BACKEND_SITE_CODE=open-source
COMMERCIAL_BACKEND_SITE_NAME=open-source
COMMERCIAL_BACKEND_TIMEOUT_SECONDS=15
# Enable only after ad-application creation has been contract-tested to honor
# the same Idempotency-Key in the request header and JSON body. Feedback always
# remains local in this open-source edition.
COMMERCIAL_BACKEND_MUTATION_IDEMPOTENCY_ENABLED=false
# Enable only after BOTH payment-order creation and payment-order close have
# been contract-tested to honor the same Idempotency-Key in the request header
# and JSON body. The safe default disables both remote writes.
COMMERCIAL_BACKEND_PAYMENT_IDEMPOTENCY_ENABLED=false
# Enable only after an integration test proves unpaid/closed/expired ad orders
# can never become active or appear in carousel/text-ad serving responses.
COMMERCIAL_BACKEND_PAID_AD_PLACEMENT_ENFORCED=false

# ===== Optional AI / RAG providers (server-side only) =====
EMBEDDING_API_KEY_FILE=./secrets/embedding-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
AI_PROVIDER_ENABLED=false
AI_PROVIDER_BASE_URL=
AI_PROVIDER_API_KEY_FILE=./secrets/ai-provider-api-key
AI_PROVIDER_MODEL=gpt-4o-mini
AI_PROVIDER_TIMEOUT_SECONDS=30

# ===== Optional integrations =====
AMAP_API_KEY_FILE=./secrets/amap-api-key
XIANYU_MTOP_APP_KEY=34839810

# ===== Optional container resource overrides =====
MYSQL_MEMORY_LIMIT=1g
MYSQL_CPU_LIMIT=1.5
REDIS_MEMORY_LIMIT=512m
REDIS_CPU_LIMIT=0.75
API_MEMORY_LIMIT=1g
API_CPU_LIMIT=2.0
SCHEDULER_MEMORY_LIMIT=1g
SCHEDULER_CPU_LIMIT=1.0
CRAWLER_MEMORY_LIMIT=2g
CRAWLER_CPU_LIMIT=2.0
CRAWLER_SHM_SIZE=512m
WEB_MEMORY_LIMIT=256m
WEB_CPU_LIMIT=0.5
