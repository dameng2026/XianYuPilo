# Xianyu Assistant production environment template
#
# 推荐使用一键启动脚本，首次运行会自动生成所有 secrets 文件并填充默认值：
#   Linux/macOS:  sh ./start.sh
#   Windows:      .\start.bat
#
# 如需手动配置：复制本文件为 .env，再按需修改。所有 *_FILE 路径指向的密钥文件
# 由 ./scripts/setup-wizard.sh（或 setup-wizard.ps1）自动生成到 ./secrets/ 目录，
# 权限 0700/0600。每个文件包含一行 UTF-8 内容，不要手工编辑已生成的随机密钥。
# 可选项即使不启用，对应的空文件也必须存在（脚本会自动 touch）。

# ===== Runtime =====
APP_ENV=production
WEB_BIND_ADDRESS=0.0.0.0
WEB_PORT=8080
# 暴露到公网前请改为实际域名，例如：
# TRUSTED_HOSTS=assistant.example.com,localhost,127.0.0.1,api
TRUSTED_HOSTS=localhost,127.0.0.1,api
TRUSTED_PROXY_IPS=172.30.240.20/32
# 同源浏览器访问无需配置 CORS；如需跨域请用逗号分隔的 HTTPS 白名单，禁止 *
CORS_ALLOWED_ORIGINS=
PUBLIC_BASE_URL=

# ===== Administrator =====
ADMIN_USERNAME=admin
# 首次启动时由脚本生成 bcrypt cost 12 hash；默认明文密码 admin123 请尽快修改。
# 手动生成：docker run --rm python:3.11-slim sh -c "pip install -q bcrypt && python -c \"import bcrypt;print(bcrypt.hashpw(b'YOUR_PASSWORD',bcrypt.gensalt(rounds=12)).decode())\""
ADMIN_PASSWORD_HASH_FILE=./secrets/admin-password-hash

# ===== MySQL =====
MYSQL_DATABASE=xianyu_opensource
MYSQL_APP_USER=xianyu_app
MYSQL_APP_PASSWORD_FILE=./secrets/mysql-app-password
MYSQL_MIGRATION_USER=xianyu_migrate
MYSQL_MIGRATION_PASSWORD_FILE=./secrets/mysql-migration-password
MYSQL_ROOT_PASSWORD_FILE=./secrets/mysql-root-password

# ===== Redis =====
REDIS_PASSWORD_FILE=./secrets/redis-password

# ===== Cryptographic boundaries =====
JWT_SECRET_FILE=./secrets/jwt-secret
COOKIE_CRYPTO_SECRET_FILE=./secrets/cookie-crypto-secret
INTERNAL_API_TOKEN_FILE=./secrets/internal-api-token
JWT_EXPIRATION_MS=43200000
JWT_ISSUER=xianyu-assistant-api
JWT_AUDIENCE=xianyu-assistant-web

# ===== API safety limits =====
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
API_RATE_LIMIT_PER_MINUTE=600
AUDIT_LOG_RETENTION_DAYS=90
# 生产预检强制要求 true；保持默认即可
AUDIT_MUTATION_INTENT_REQUIRED=true
MAX_REQUEST_BODY_BYTES=12582912
MAX_UPLOAD_BYTES=10485760

# ===== Scheduled task worker =====
SCHEDULER_POLL_INTERVAL_SECONDS=15
SCHEDULER_TASK_TIMEOUT_SECONDS=300
SCHEDULER_LEASE_SECONDS=360
SCHEDULER_BATCH_SIZE=20
SCHEDULER_HEARTBEAT_MAX_AGE_SECONDS=60

# ===== 自动发货补发兜底循环 =====
# 扫描已开启自动发货但未发出的订单，复用幂等状态机安全补发。
DELIVERY_RECOVERY_ENABLED=true
DELIVERY_RECOVERY_INTERVAL_SECONDS=600
DELIVERY_RECOVERY_BATCH_SIZE=50
DELIVERY_RECOVERY_MIN_AGE_SECONDS=300

# ===== Crawler service =====
CRAWLER_JSON_LIMIT=256kb
CRAWLER_RATE_LIMIT_WINDOW_MS=60000
CRAWLER_RATE_LIMIT_MAX=60
CRAWLER_MAX_CONCURRENCY=2
CRAWLER_MAX_SESSIONS=100
CRAWLER_SESSION_TTL_MS=1800000
CRAWLER_OPERATION_TIMEOUT_MS=180000
CRAWLER_MAX_COOKIE_BYTES=65536
CRAWLER_ALLOWED_TARGET_HOSTS=goofish.com,taobao.com
CRAWLER_ALLOWED_ORIGINS=
CRAWLER_FORCE_HEADLESS=true
PLAYWRIGHT_DISABLE_SANDBOX=true

# ===== Optional commercial bridge =====
# 商业版桥接配置：配置后开源版可对接商业版后端，启用广告申请、广告套餐展示、
# 支付订单等功能。全部留空则禁用商业版桥接，使用本地兜底数据。
#
# 启用广告申请功能需要以下 5 步：
# 1. 在商业版 .env.production 中配置 OPEN_SOURCE_BRIDGE_TOKEN=<至少32字符随机字符串>
# 2. 将该 token 写入本机 ./secrets/commercial-backend-access-token 文件（一行 UTF-8）
# 3. 设置下方 COMMERCIAL_BACKEND_BASE_URL 为商业版后端地址（如 https://api.example.com）
# 4. 将下方三个能力开关全部改为 true：
#    COMMERCIAL_BACKEND_MUTATION_IDEMPOTENCY_ENABLED=true
#    COMMERCIAL_BACKEND_PAYMENT_IDEMPOTENCY_ENABLED=true
#    COMMERCIAL_BACKEND_PAID_AD_PLACEMENT_ENFORCED=true
# 5. 在商业版后台 admin-web 的"开源版广告套餐"页面配置至少一个 home_carousel 套餐
#    和一个 sidebar_text 套餐，并在"开源版文字广告"页面配置文字广告（可选）
# token 不一致或能力开关任一为 false 时，前台会显示"广告申请已关闭"
COMMERCIAL_FRONTEND_URL=
COMMERCIAL_ADMIN_URL=
COMMERCIAL_BACKEND_BASE_URL=
COMMERCIAL_BACKEND_HEALTH_PATH=/admin-api/health
COMMERCIAL_BACKEND_ADMIN_HEALTH_PATH=/admin-api/health
COMMERCIAL_BACKEND_USER_HEALTH_PATH=/api/health
COMMERCIAL_BACKEND_BRIDGE_PREFIX=/admin-api/open-source-bridge
COMMERCIAL_BACKEND_ACCESS_TOKEN_FILE=./secrets/commercial-backend-access-token
COMMERCIAL_BACKEND_SITE_CODE=open-source
COMMERCIAL_BACKEND_SITE_NAME=open-source
COMMERCIAL_BACKEND_TIMEOUT_SECONDS=15
COMMERCIAL_BACKEND_MUTATION_IDEMPOTENCY_ENABLED=false
COMMERCIAL_BACKEND_PAYMENT_IDEMPOTENCY_ENABLED=false
COMMERCIAL_BACKEND_PAID_AD_PLACEMENT_ENFORCED=false

# ===== Optional AI / RAG providers =====
EMBEDDING_API_KEY_FILE=./secrets/embedding-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
AI_PROVIDER_ENABLED=false
AI_PROVIDER_BASE_URL=
AI_PROVIDER_API_KEY_FILE=./secrets/ai-provider-api-key
AI_PROVIDER_MODEL=gpt-4o-mini
AI_PROVIDER_TIMEOUT_SECONDS=30

# ===== Optional integrations =====
AMAP_API_KEY_FILE=./secrets/amap-api-key
XIANYU_MTOP_APP_KEY=34839810

# ===== Update checker =====
GITHUB_REPO=xianyu-assistant-opensource/xianyu-assistant-opensource
# 阿里云 ACR 镜像源地址（用于"关于我们"页面展示镜像拉取命令，留空则不展示 ACR tab）。
# 默认指向国内镜像源；海外部署可留空或改为 GHCR。
ACR_REGISTRY_URL=registry.cn-hangzhou.aliyuncs.com/xianyu-assistant

# ===== Prebuilt Docker images =====
# 默认拉取阿里云 ACR（国内拉取快）上由 GitHub Actions 同步的预构建镜像。
# 一键运行：sh ./start.sh  或  docker compose pull && docker compose up -d
# 本地构建：docker compose up -d --build
#
# 镜像源切换：默认使用阿里云 ACR（国内推荐）；海外部署或 ACR 不可达时改用 GHCR。
# 修改地域/命名空间时，同步更新 docker-compose.yml 三个服务的 image 默认值、
# docker-publish.yml 的 ACR Variables、以及此处，保持四处一致。
#
# —— 阿里云 ACR（默认，国内推荐）——
# 完整地址：registry.cn-hangzhou.aliyuncs.com/xianyu-assistant/xianyu-assistant-{api,web,crawler}:latest
# 如需更换地域或命名空间，取消注释并修改：
# API_IMAGE=registry.cn-hangzhou.aliyuncs.com/xianyu-assistant/xianyu-assistant-api:latest
# WEB_IMAGE=registry.cn-hangzhou.aliyuncs.com/xianyu-assistant/xianyu-assistant-web:latest
# CRAWLER_IMAGE=registry.cn-hangzhou.aliyuncs.com/xianyu-assistant/xianyu-assistant-crawler:latest
#
# —— GHCR（海外部署或 ACR 不可达时使用）——
# API_IMAGE=ghcr.io/xianyu-assistant-opensource/xianyu-assistant-api:latest
# WEB_IMAGE=ghcr.io/xianyu-assistant-opensource/xianyu-assistant-web:latest
# CRAWLER_IMAGE=ghcr.io/xianyu-assistant-opensource/xianyu-assistant-crawler:latest

# ===== Optional container resource overrides =====
MYSQL_MEMORY_LIMIT=1g
MYSQL_CPU_LIMIT=1.5
REDIS_MEMORY_LIMIT=512m
REDIS_CPU_LIMIT=0.75
API_MEMORY_LIMIT=1g
API_CPU_LIMIT=2.0
SCHEDULER_MEMORY_LIMIT=1g
SCHEDULER_CPU_LIMIT=1.0
CRAWLER_MEMORY_LIMIT=2g
CRAWLER_CPU_LIMIT=2.0
CRAWLER_SHM_SIZE=512m
WEB_MEMORY_LIMIT=256m
WEB_CPU_LIMIT=0.5
