# Same-host TLS edge for the reference loopback-only Compose deployment.
# Replace assistant.example.com and certificate paths before nginx -t. Keep the
# upstream on 127.0.0.1; exposing port 8080 directly bypasses this trust boundary.

limit_req_zone $binary_remote_addr zone=xianyu_ready_per_ip:10m rate=2r/s;

server {
  listen 80;
  listen [::]:80;
  server_name assistant.example.com;
  return 308 https://$host$request_uri;
}

server {
  listen 443 ssl;
  listen [::]:443 ssl;
  http2 on;
  server_name assistant.example.com;
  server_tokens off;

  ssl_certificate /etc/letsencrypt/live/assistant.example.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/assistant.example.com/privkey.pem;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_session_cache shared:XianYuTLS:10m;
  ssl_session_timeout 1d;
  ssl_session_tickets off;

  client_max_body_size 12m;
  client_body_timeout 30s;
  proxy_connect_timeout 5s;
  proxy_send_timeout 310s;
  proxy_read_timeout 310s;

  add_header Strict-Transport-Security "max-age=31536000" always;

  location = /readyz {
    limit_req zone=xianyu_ready_per_ip burst=4 nodelay;
    proxy_pass http://127.0.0.1:8080;
    proxy_http_version 1.1;
    proxy_connect_timeout 3s;
    proxy_send_timeout 5s;
    proxy_read_timeout 5s;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-Proto https;
  }

  location /api/sse/ {
    proxy_pass http://127.0.0.1:8080;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_buffering off;
    proxy_cache off;
    proxy_read_timeout 65m;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-Proto https;
  }

  location / {
    proxy_pass http://127.0.0.1:8080;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    # Overwrite attacker-supplied forwarding headers; never append them here.
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-Proto https;
  }
}
